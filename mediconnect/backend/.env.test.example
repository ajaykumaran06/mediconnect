# backend/.env.test.example
# Copy to .env.test for running tests against a real Supabase test project
# Never use your production Supabase project for tests

NODE_ENV=test
PORT=5001

# Use a dedicated TEST Supabase project
SUPABASE_URL=https://your-test-project.supabase.co
SUPABASE_ANON_KEY=your_test_anon_key
SUPABASE_SERVICE_KEY=your_test_service_role_key

# JWT — any 32+ char string works for tests
JWT_SECRET=test-secret-key-minimum-32-characters-long
JWT_EXPIRES_IN=1h

# Optional: provide an admin JWT if you want to run admin route tests
# Generate with: node -e "const j=require('jsonwebtoken'); console.log(j.sign({userId:'admin-id',role:'admin'},'test-secret-key-minimum-32-characters-long',{expiresIn:'1h'}))"
TEST_ADMIN_TOKEN=

# Frontend URL (for CORS in test)
FRONTEND_URL=http://localhost:3000
